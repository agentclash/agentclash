# WorkOS AuthKit (required)
WORKOS_CLIENT_ID=client_01...
WORKOS_API_KEY=sk_test_...
WORKOS_COOKIE_PASSWORD=<generate with: openssl rand -base64 24>
NEXT_PUBLIC_WORKOS_REDIRECT_URI=http://localhost:3000/auth/callback

# Backend API URL
NEXT_PUBLIC_API_URL=http://localhost:8080
# API_URL=http://localhost:8080

# Try CLI service (interactive terminal demos)
TRY_CLI_API_URL=http://localhost:3001
NEXT_PUBLIC_TRY_CLI_WS_URL=ws://localhost:3001
NEXT_PUBLIC_TRY_CLI_API_URL=/api/try
NEXT_PUBLIC_TRY_CLI_PUBLIC_URL=http://localhost:3000/try

# IndexNow (Bing/Yandex/Naver/Seznam/Yep — NOT Google). Must match web/public/<KEY>.txt.
INDEXNOW_KEY=265a46be97a2ce1f8891dd452d243327
# Protects /api/indexnow; Vercel Cron sends it automatically. Generate: openssl rand -hex 32
CRON_SECRET=

# SEO webmaster verification (public tokens; safe in HTML; leave blank to render no meta tag)
NEXT_PUBLIC_GSC_VERIFICATION=
NEXT_PUBLIC_BING_VERIFICATION=

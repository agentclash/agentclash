FROM golang:1.24-alpine AS builder
WORKDIR /app
COPY go.mod go.sum ./
RUN go mod download
COPY . .
RUN CGO_ENABLED=0 go build -trimpath -ldflags="-s -w" -o /worker ./cmd/worker

FROM alpine:3.21
RUN apk --no-cache add ca-certificates docker-cli
COPY --from=builder /worker /worker
ENTRYPOINT ["/worker"]

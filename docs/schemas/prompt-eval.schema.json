{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://agentclash.dev/schemas/prompt-eval.schema.json",
  "title": "AgentClash Prompt Eval Config",
  "type": "object",
  "required": ["schemaVersion", "name", "prompt", "models", "tests"],
  "additionalProperties": false,
  "properties": {
    "schemaVersion": {
      "const": 1
    },
    "name": {
      "type": "string",
      "minLength": 1
    },
    "prompt": {
      "type": "object",
      "required": ["template"],
      "additionalProperties": false,
      "properties": {
        "template": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "models": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "properties": {
          "alias": {
            "type": "string"
          },
          "model_alias_id": {
            "type": "string"
          },
          "provider_account": {
            "type": "string"
          }
        },
        "anyOf": [
          { "required": ["alias"] },
          { "required": ["model_alias_id"] }
        ]
      }
    },
    "tests": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["key"],
        "additionalProperties": false,
        "properties": {
          "key": {
            "type": "string",
            "minLength": 1
          },
          "vars": {
            "type": "object",
            "additionalProperties": true
          },
          "expect": {
            "type": "object",
            "additionalProperties": false,
            "properties": {
              "output": true
            }
          },
          "assert": {
            "type": "array",
            "items": {
              "type": "object",
              "required": ["type"],
              "additionalProperties": false,
              "properties": {
                "type": {
                  "enum": ["exact_match", "equals", "contains", "regex_match", "regex", "json_schema", "json_path_match", "boolean_assert"]
                },
                "value": true,
                "metric": {
                  "type": "string"
                }
              }
            }
          }
        }
      }
    },
    "thresholds": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "assertion_pass_rate": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        },
        "dimensions": {
          "type": "object",
          "additionalProperties": {
            "type": "number",
            "minimum": 0,
            "maximum": 1
          }
        }
      }
    }
  }
}
